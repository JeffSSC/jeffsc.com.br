---
const { isBlog = false } = Astro.props;
---
<footer class={`pt-20 ${isBlog ? "" : "border-t border-rule mt-20"}`}>
  {!isBlog && <div class="serif tracking-[-0.04em] leading-none mb-7 hidden md:block" style="font-size: clamp(60px, 14vw, 200px);">Jefferson Silva <em class="italic text-accent">Caires.</em></div>}
  <div class="flex flex-wrap justify-between gap-4 pt-5 border-t border-rule">
    <span class="mono">© 2026<span class="hidden md:inline"> · Built with Astro, Typescript & care</span></span>
    <span class="mono hidden md:inline">Designed with Claude Design</span>
    <span class="mono hidden md:inline">Last refactor · Apr 2026</span>
    <a class="mono hover:text-accent" href="#top">Back to top ↑</a>
  </div>
</footer>
