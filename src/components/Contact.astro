---
import { getData, type DataLang } from "../i18n/data";

interface Props {
  lang: DataLang;
}

const { lang } = Astro.props;
const data = getData(lang);

const cards = [
  { num: `01 · ${lang === "pt" ? "Qualquer hora" : "Anytime"}`, label: lang === "pt" ? "E-mail" : "Email", sub: `${data.contact.email} →`, href: `mailto:${data.contact.email}` },
  { num: `02 · ${lang === "pt" ? "Profissional" : "Professional"}`, label: "LinkedIn", sub: "/in/jefferson-caires →", href: data.contact.linkedin },
  { num: `03 · ${lang === "pt" ? "Código" : "Code"}`, label: "GitHub", sub: "/JeffSSC →", href: data.contact.github },
];
---
<section id="contact" class="py-24 md:py-14">
  <header class="grid md:grid-cols-[1fr_2fr_1fr] gap-10 items-end mb-14">
    <div class="flex flex-col gap-1">
      <span class="mono text-ink">05</span>
      <span class="mono">{lang === "pt" ? "Índice · Contato" : "Index · Contact"}</span>
    </div>
    <h2 class="serif m-0 tracking-[-0.03em] leading-[1.02]" style="font-size: clamp(38px, 6vw, 72px);">
      {lang === "pt" ? "Vamos construir" : "Let's build"}<br />
      <em class="quiet">{lang === "pt" ? "algo juntos." : "something together."}</em>
    </h2>
  </header>
  <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-px bg-rule border border-rule">
    {cards.map((c) => (
      <a href={c.href} target="_blank" rel="noopener"
        class="bg-bg p-7 flex flex-col gap-3 min-h-[180px] transition-colors hover:bg-ink hover:text-bg contact-card">
        <span class="mono">{c.num}</span>
        <span class="serif text-[38px] tracking-[-0.02em] leading-none mt-2">{c.label}</span>
        <span class="mono mt-auto">{c.sub}</span>
      </a>
    ))}
  </div>
</section>
<style is:global>
  .contact-card:hover .mono { color: color-mix(in srgb, var(--bg) 60%, transparent); }
</style>
